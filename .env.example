# =============================================================================
# VAPT Web Application - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# Never commit .env to version control.
# =============================================================================

# ---- General ----
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-this-to-a-long-random-secret-key
APP_NAME=VAPT Platform
APP_VERSION=1.0.0
LOG_LEVEL=INFO
TIMEZONE=UTC
PROJECT_NAME=VAPT
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Frontend ----
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws
VITE_APP_TITLE=VAPT Platform
VITE_ENABLE_MOCK_API=false
VITE_SENTRY_DSN=
VITE_APP_VERSION=1.0.0
VITE_POSTHOG_KEY=

# ---- PostgreSQL Database ----
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=vapt_user
POSTGRES_PASSWORD=vapt_strong_password_2024
POSTGRES_DB=vapt
POSTGRES_MAX_CONNECTIONS=100
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_SYNC_URL=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:${POSTGRES_PORT}/${POSTGRES_DB}

# ---- TimescaleDB (Time-series data) ----
TIMESCALE_SERVER=localhost
TIMESCALE_PORT=5433
TIMESCALE_USER=vapt_ts_user
TIMESCALE_PASSWORD=vapt_ts_password_2024
TIMESCALE_DB=vapt_ts
TIMESCALE_URL=postgresql+asyncpg://${TIMESCALE_USER}:${TIMESCALE_PASSWORD}@${TIMESCALE_SERVER}:${TIMESCALE_PORT}/${TIMESCALE_DB}

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}
REDIS_CACHE_TTL=3600
REDIS_SESSION_TTL=86400

# ---- Celery ----
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/2
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_SOFT_TIME_LIMIT=7200
CELERY_TASK_TIME_LIMIT=7800
CELERY_BEAT_SCHEDULE_ENABLED=true

# ---- JWT Authentication ----
JWT_SECRET_KEY=change-this-to-a-long-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=vapt-platform
JWT_AUDIENCE=vapt-users

# ---- OAuth2 / SSO ----
OAUTH_ENABLED=false
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=

# ---- MinIO / S3 Storage ----
S3_ENABLED=true
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=vapt_minio
S3_SECRET_KEY=vapt_minio_secret_2024
S3_BUCKET_REPORTS=vapt-reports
S3_BUCKET_SCREENSHOTS=vapt-screenshots
S3_BUCKET_SCAN_RESULTS=vapt-scan-results
S3_BUCKET_LOGS=vapt-logs
S3_REGION=us-east-1
S3_USE_SSL=false

# ---- Elasticsearch ----
ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USER=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_PREFIX=vapt-
ELASTICSEARCH_VERIFY_CERTS=false

# ---- Scanning Engine ----
SCANNER_NUCLEI_ENABLED=true
SCANNER_NUCLEI_CONCURRENCY=10
SCANNER_NUCLEI_SEVERITY=critical,high,medium,low,info
SCANNER_NUCLEI_RATE_LIMIT=150

SCANNER_ZAP_ENABLED=true
SCANNER_ZAP_API_KEY=change-me-zap-api-key
SCANNER_ZAP_HOST=zap
SCANNER_ZAP_PORT=8090
SCANNER_ZAP_RATE_LIMIT=10

SCANNER_NMAP_ENABLED=true
SCANNER_NMAP_RATE_LIMIT=1000
SCANNER_NMAP_TIMING_TEMPLATE=T4

SCANNER_SUBFINDER_ENABLED=true
SCANNER_FFUF_ENABLED=true
SCANNER_FFUF_WORDLIST=/wordlists/common.txt

SCANNER_CUSTOM_ENABLED=true
SCANNER_TIMEOUT_SECONDS=300
SCANNER_MAX_TARGETS_PER_SCAN=100
SCANNER_MAX_CONCURRENT_SCANS=5
SCANNER_MAX_RETRIES=3

# ---- Rate Limiting ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_API_PER_MINUTE=120

# ---- OWASP ZAP Configuration ----
ZAP_API_KEY=change-me-zap-api-key
ZAP_HOST=zap
ZAP_PORT=8090
ZAP_ATTACK_STRENGTH=DEFAULT
ZAP_ALERT_THRESHOLD=DEFAULT

# ---- SMTP / Email ----
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@vapt-platform.com
SMTP_USE_TLS=true

# ---- Monitoring & Observability ----
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_ENABLED=true
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

SENTRY_DSN=
SENTRY_ENVIRONMENT=${ENVIRONMENT}
SENTRY_TRACES_SAMPLE_RATE=0.2

# ---- Security ----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
CSRF_PROTECTION_ENABLED=true
CSRF_COOKIE_NAME=vapt-csrf
CSRF_COOKIE_SECURE=false
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true
SECURE_CONTENT_SECURITY_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' ws: wss:
SECURE_XSS_PROTECTION=true
SECURE_FRAME_DENY=true
SECURE_CONTENT_TYPE_NOSNIFF=true
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin

# ---- Admin User (First Run) ----
FIRST_SUPERUSER_EMAIL=admin@vapt-platform.com
FIRST_SUPERUSER_PASSWORD=Admin123!@#
FIRST_SUPERUSER_FIRST_NAME=Admin
FIRST_SUPERUSER_LAST_NAME=User

# ---- Docker ----
DOCKER_NETWORK=vapt-network
DOCKER_REGISTRY=
DOCKER_IMAGE_TAG=latest

# ---- Kubernetes ----
K8S_NAMESPACE=vapt
K8S_STORAGE_CLASS=standard
K8S_SCANNER_NODE_SELECTOR=scanner-pool
K8S_REPLICA_COUNT_API=3
K8S_REPLICA_COUNT_WORKER=5
K8S_REPLICA_COUNT_FRONTEND=2
K8S_INGRESS_HOST=vapt.example.com
K8S_INGRESS_TLS_SECRET=vapt-tls

# ---- Feature Flags ----
FEATURE_SCHEDULED_SCANS=true
FEATURE_TEAM_COLLABORATION=true
FEATURE_REPORT_SCHEDULING=true
FEATURE_INTEGRATION_WEBHOOKS=true

# ---- Flask Webhook Service ----
WEBHOOK_SECRET=change-me-webhook-secret
FLASK_PORT=5000
FEATURE_SLACK_NOTIFICATIONS=false
FEATURE_EMAIL_ALERTS=false
FEATURE_DASHBOARD_WIDGETS=true
FEATURE_CUSTOM_SEVERITY=true
