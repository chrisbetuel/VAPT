# Production Environment - Overrides for .env
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
POSTGRES_SERVER=postgres.prod.svc.cluster.local
REDIS_HOST=redis.prod.svc.cluster.local
S3_ENDPOINT=https://s3.amazonaws.com
ELASTICSEARCH_HOST=elasticsearch.prod.svc.cluster.local
CELERY_BROKER_URL=redis://redis.prod.svc.cluster.local:6379/1
CELERY_RESULT_BACKEND=redis://redis.prod.svc.cluster.local:6379/2
DATABASE_URL=postgresql+asyncpg://vapt_user:${POSTGRES_PASSWORD}@postgres.prod.svc.cluster.local:5432/vapt
CORS_ORIGINS=https://app.vapt-platform.com
BACKEND_CORS_ORIGINS=https://app.vapt-platform.com
VITE_API_BASE_URL=https://api.vapt-platform.com/api/v1
VITE_WS_URL=wss://api.vapt-platform.com/ws
RATE_LIMIT_REQUESTS_PER_MINUTE=120
RATE_LIMIT_LOGIN_PER_MINUTE=5
SECURE_SSL_REDIRECT=true
CSRF_COOKIE_SECURE=true
SENTRY_TRACES_SAMPLE_RATE=0.1
SCANNER_MAX_CONCURRENT_SCANS=10
