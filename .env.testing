# Testing Environment - Overrides for .env
ENVIRONMENT=testing
DEBUG=true
LOG_LEVEL=DEBUG
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vapt_test
REDIS_DB=10
S3_ENABLED=false
ELASTICSEARCH_ENABLED=false
RATE_LIMIT_ENABLED=false
SCANNER_NUCLEI_ENABLED=false
SCANNER_ZAP_ENABLED=false
SCANNER_NMAP_ENABLED=false
SCANNER_SUBFINDER_ENABLED=false
SCANNER_FFUF_ENABLED=false
SCANNER_CUSTOM_ENABLED=false
FEATURE_SCHEDULED_SCANS=false
FEATURE_INTEGRATION_WEBHOOKS=false
DATABASE_URL=postgresql+asyncpg://vapt_user:vapt_strong_password_2024@localhost:5432/vapt_test
DATABASE_SYNC_URL=postgresql+psycopg2://vapt_user:vapt_strong_password_2024@localhost:5432/vapt_test
VITE_ENABLE_MOCK_API=true
